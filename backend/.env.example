# Comma-separated frontend origins allowed by the API (add your Vercel URL)
ALLOWED_ORIGINS=https://your-app.vercel.app

# Also allow any *.vercel.app origin (production aliases + preview deploys)
SNAPIC_ALLOW_VERCEL=true
# Or set an explicit regex instead:
# ALLOWED_ORIGIN_REGEX=https://.*\.vercel\.app

# Face model (buffalo_l = best accuracy, needs ~1 GB+ RAM; buffalo_s fits 512 MB on Render)
# SNAPIC_FACE_MODEL=buffalo_l
# SNAPIC_DET_SIZE=640
