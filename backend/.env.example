# Comma-separated frontend origins allowed by the API (add your Vercel URL)
ALLOWED_ORIGINS=https://frontend-seven-mocha-96.vercel.app

SNAPIC_ALLOW_VERCEL=true

# Supabase (required for auth + persistence)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_JWT_SECRET=your-jwt-secret
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Face model
# SNAPIC_FACE_MODEL=buffalo_l
# SNAPIC_DET_SIZE=640
